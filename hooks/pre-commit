#!/bin/bash
# Peut-Être — Pre-Commit Hook
# Runs: compilation check + test suite

echo "Pre-commit: on vérifie que ça compile..."

# Check if any C source files are staged
if git diff --cached --name-only | grep -qE '\.(c|h)$'; then
    # Build
    if ! make -s 2>&1; then
        echo ""
        echo "  \033[31mErreur: ça compile pas. Corrige avant de commit.\033[0m"
        exit 1
    fi
    echo "  \033[32m✓\033[0m Compilation OK"

    # Run tests
    echo "Pre-commit: on lance les tests..."
    if ! ./tests/run_tests.sh > /dev/null 2>&1; then
        echo ""
        echo "  \033[31mErreur: des tests ont échoué.\033[0m"
        echo "  Lance 'make test' pour voir lesquels."
        exit 1
    fi
    echo "  \033[32m✓\033[0m Tests OK"
else
    echo "  Pas de fichiers C modifiés, on skippe la compilation."
fi

echo ""
exit 0
